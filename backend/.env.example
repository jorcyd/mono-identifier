# Backend de identificação de fontes monospace — configuração

# URL do backend upstream (Claude Vision) para os endpoints /api/identify e /api/identify-url.
# Este serviço é imutável — este backend apenas faz proxy + preprocess + re-rank.
UPSTREAM_BASE_URL=https://upstream.example.com

# Token de autenticação enviado no header Authorization ao upstream (opcional).
UPSTREAM_API_KEY=

# Origens permitidas (CORS). Separar múltiplas por vírgula.
# Para dev típico: http://localhost:5500,http://127.0.0.1:5500
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000

# Re-ranking visual — habilita a comparação pixel-a-pixel após resposta do upstream.
ENABLE_RERANK=true

# Cache de respostas por hash da imagem. TTL em segundos (padrão 7 dias).
CACHE_TTL_SECONDS=604800

# Diretório de cache (relativo ao backend/).
CACHE_DIR=cache
FONTS_CACHE_DIR=fonts_cache

# Timeout da chamada ao upstream em segundos.
UPSTREAM_TIMEOUT=60

# Preprocessamento — tamanho alvo (lado maior) pra upscale.
TARGET_LONG_EDGE=1600
MIN_LONG_EDGE_FOR_UPSCALE=1200
